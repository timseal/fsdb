<h1 class="text-2xl font-bold mb-2">Category: <%= @category.name %></h1>
<p class="text-sm text-gray-500 mb-6">
  <%= link_to "&larr; All categories".html_safe, categories_path, class: "text-blue-600 hover:underline" %>
</p>

<% if @entries.any? %>
  <table class="w-full bg-white rounded-lg shadow text-sm">
    <thead>
      <tr class="text-left text-gray-500 border-b">
        <th class="py-2 px-3">Path</th>
        <th class="py-2 px-3">Type</th>
        <th class="py-2 px-3">Tags</th>
        <th class="py-2 px-3"></th>
      </tr>
    </thead>
    <tbody>
      <% @entries.each do |entry| %>
        <%= render "shared/entry_row", entry: entry %>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-gray-500">No entries in this category.</p>
<% end %>
