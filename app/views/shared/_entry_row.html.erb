<tr class="border-b border-gray-100 hover:bg-gray-50" id="<%= dom_id(entry) %>">
  <td class="py-2 px-3">
    <% if entry.dir? %>
      <%= link_to entry.name, browse_path(path: entry.path), class: "text-blue-600 hover:underline font-medium" %>
    <% else %>
      <span><%= entry.name %></span>
    <% end %>
  </td>
  <td class="py-2 px-3">
    <span class="px-2 py-0.5 rounded text-xs <%= type_badge_class(entry.display_type) %>">
      <%= entry.display_type %>
    </span>
  </td>
  <td class="py-2 px-3">
    <%= render "shared/tag_badges", entry: entry %>
  </td>
  <td class="py-2 px-3">
    <%= render "shared/tag_form", entry: entry %>
  </td>
</tr>
