<h1 class="text-2xl font-bold mb-6">Dashboard</h1>

<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-sm text-gray-500">Entries</div>
    <div class="text-2xl font-bold"><%= number_with_delimiter(@stats[:total_entries]) %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-sm text-gray-500">Files</div>
    <div class="text-2xl font-bold"><%= number_with_delimiter(@stats[:total_files]) %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-sm text-gray-500">Directories</div>
    <div class="text-2xl font-bold"><%= number_with_delimiter(@stats[:total_dirs]) %></div>
  </div>
  <div class="bg-white rounded-lg shadow p-4">
    <div class="text-sm text-gray-500">Total size</div>
    <div class="text-2xl font-bold"><%= humanize_bytes(@stats[:total_size]) %></div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <% if @stats[:by_type].any? %>
    <div class="bg-white rounded-lg shadow p-4">
      <h2 class="font-bold mb-3">By content type</h2>
      <table class="w-full text-sm">
        <thead><tr class="text-left text-gray-500 border-b">
          <th class="py-1">Type</th><th class="py-1 text-right">Files</th><th class="py-1 text-right">Size</th>
        </tr></thead>
        <tbody>
          <% @stats[:by_type].each do |row| %>
            <tr class="border-b border-gray-50">
              <td class="py-1"><span class="px-2 py-0.5 rounded text-xs <%= type_badge_class(row[:type]) %>"><%= row[:type] %></span></td>
              <td class="py-1 text-right"><%= number_with_delimiter(row[:count]) %></td>
              <td class="py-1 text-right"><%= humanize_bytes(row[:size]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>

  <div class="bg-white rounded-lg shadow p-4">
    <h2 class="font-bold mb-3">Top categories</h2>
    <% if @stats[:top_categories].any? %>
      <table class="w-full text-sm">
        <thead><tr class="text-left text-gray-500 border-b">
          <th class="py-1">Category</th><th class="py-1 text-right">Entries</th>
        </tr></thead>
        <tbody>
          <% @stats[:top_categories].each do |row| %>
            <tr class="border-b border-gray-50">
              <td class="py-1"><%= row[:name] %></td>
              <td class="py-1 text-right"><%= row[:count] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
    <p class="mt-3 text-sm text-gray-500">
      <%= link_to "#{number_with_delimiter(@stats[:uncategorised])} uncategorised", search_path(uncategorised: 1), class: "text-blue-600 hover:underline" %>
    </p>
  </div>
</div>
